{
  "expo": {
    "name": "APPACC Mobile",
    "slug": "appacc-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1b4b"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1b4b"
      },
      "package": "com.appacc.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "95185d8a-0ee1-4deb-83ec-c266d49009ff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.appacc.mobile"
    }
  }
}
